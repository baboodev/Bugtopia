# Recommended BepInEx logging settings for Bugtopia
# Copy these lines into your game's BepInEx/config/BepInEx.cfg [Logging.Console] / [Logging.Disk] sections.

[Logging.Console]
Enabled = true
LogLevels = Fatal, Error, Warning, Message, Info

[Logging.Disk]
Enabled = true
LogLevels = Fatal, Error, Warning, Message, Info

# Mod-specific backup log (written by bugtopia.dll):
#   {GameFolder}\UserData\bugtopia.log
