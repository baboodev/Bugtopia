  <Import Project="Version.targets" />

  <!-- Auto-deploy the built mod into the game so a rebuild is picked up on the next launch.
       Universal deploys to both loader folders; a single-loader build deploys only to its folder.
       A running game locks the DLL; the copy then fails with a clear warning (ContinueOnError). -->
  <Target Name="DeployModToGame" AfterTargets="Build" Condition="'$(ContinuousIntegrationBuild)' != 'true'">
    <ItemGroup>
      <UnifiedDeployDir Include="$(HeartopiaDir)\Mods"
        Condition="Exists('$(HeartopiaDir)\Mods') And ('$(Loader)' == 'Universal' Or '$(Loader)' == 'MelonLoader')" />
      <UnifiedDeployDir Include="$(HeartopiaDir)\BepInEx\plugins"
        Condition="Exists('$(HeartopiaDir)\BepInEx\plugins') And ('$(Loader)' == 'Universal' Or '$(Loader)' == 'BepInEx')" />
    </ItemGroup>
    <Copy SourceFiles="$(OutputPath)bugtopia.dll"
          DestinationFolder="%(UnifiedDeployDir.Identity)"
          ContinueOnError="true"
          Condition="'@(UnifiedDeployDir)' != ''">
      <Output TaskParameter="CopiedFiles" ItemName="DeployedDll" />
    </Copy>
    <Copy SourceFiles="$(OutputPath)bugtopia.pdb"
          DestinationFolder="%(UnifiedDeployDir.Identity)"
          ContinueOnError="true"
          Condition="'@(UnifiedDeployDir)' != '' and Exists('$(OutputPath)bugtopia.pdb')" />
    <Message Importance="high"
             Text="Deployed bugtopia.dll -> %(UnifiedDeployDir.Identity)"
             Condition="'@(UnifiedDeployDir)' != ''" />
    <Warning Text="No loader folder found under $(HeartopiaDir) to deploy bugtopia.dll into (Loader=$(Loader))."
             Condition="'@(UnifiedDeployDir)' == ''" />
  </Target>
