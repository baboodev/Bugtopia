  <!-- Auto-deploy the built mod into the game so a rebuild is actually picked up on the next
       game launch. One unified DLL serves both loaders, so it is copied into whichever loader
       folders exist (Mods\ for MelonLoader, BepInEx\plugins\ for BepInEx). If the game is running
       it holds a lock on the plugin DLL; the copy then fails with a clear warning (ContinueOnError)
       instead of silently doing nothing. -->
  <Target Name="DeployModToGame" AfterTargets="Build" Condition="'$(ContinuousIntegrationBuild)' != 'true'">
    <ItemGroup>
      <UnifiedDeployDir Include="$(HeartopiaDir)\Mods" Condition="Exists('$(HeartopiaDir)\Mods')" />
      <UnifiedDeployDir Include="$(HeartopiaDir)\BepInEx\plugins" Condition="Exists('$(HeartopiaDir)\BepInEx\plugins')" />
    </ItemGroup>
    <Copy SourceFiles="$(OutputPath)bugtopia.dll"
          DestinationFolder="%(UnifiedDeployDir.Identity)"
          ContinueOnError="true"
          Condition="'@(UnifiedDeployDir)' != ''">
      <Output TaskParameter="CopiedFiles" ItemName="DeployedDll" />
    </Copy>
    <Copy SourceFiles="$(OutputPath)bugtopia.pdb"
          DestinationFolder="%(UnifiedDeployDir.Identity)"
          ContinueOnError="true"
          Condition="'@(UnifiedDeployDir)' != '' and Exists('$(OutputPath)bugtopia.pdb')" />
    <Message Importance="high"
             Text="Deployed bugtopia.dll -> %(UnifiedDeployDir.Identity)"
             Condition="'@(UnifiedDeployDir)' != ''" />
    <Warning Text="No loader folder found under $(HeartopiaDir) (Mods\ or BepInEx\plugins\) to deploy bugtopia.dll into."
             Condition="'@(UnifiedDeployDir)' == ''" />
  </Target>
